<view class="login-container">
  <view class="login-header">
    <image class="logo" src="/static/logo.png" mode="aspectFit"></image>
    <text class="app-name">备忘录</text>
    <text class="app-desc">记录重要时刻，倒计时美好未来</text>
  </view>

  <view class="login-content">
    <!-- 用户信息展示 -->
    <view class="user-info" wx:if="{{hasUserInfo && userInfo}}">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text class="nickname">{{userInfo.nickName}}</text>
    </view>

    <!-- 未登录状态 -->
    <view class="login-actions" wx:else>
      <!-- 新版微信登录 -->
      <button
        wx:if="{{canIUseGetUserProfile}}"
        class="login-btn profile-login"
        bindtap="onWxLogin"
        loading="{{loading}}"
        disabled="{{isLogining}}"
      >
        <text class="btn-icon">👤</text>
        <text class="btn-text">{{isLogining ? '登录中...' : '微信快速登录'}}</text>
      </button>

      <!-- 旧版微信登录 -->
      <button
        wx:else
        class="login-btn wx-login"
        open-type="getUserInfo"
        bindgetuserinfo="getUserInfo"
        bindfail="onUserInfoFail"
        loading="{{loading}}"
        disabled="{{isLogining}}"
      >
        <text class="btn-icon">👤</text>
        <text class="btn-text">{{isLogining ? '登录中...' : '微信快速登录'}}</text>
      </button>
    </view>

    <!-- 其他登录方式 -->
    <view class="other-login">
      <view class="divider">
        <text class="divider-text">其他登录方式</text>
      </view>

      <button class="other-login-btn" bindtap="goToPhoneLogin">
        <text class="other-icon">📱</text>
        <text class="other-text">手机号登录</text>
      </button>
    </view>

    <!-- 登录说明 -->
    <view class="login-tips">
      <text class="tips-text">
        • 登录即表示同意《用户服务协议》和《隐私政策》
      </text>
      <text class="tips-text">
        • 我们将保护您的个人信息安全
      </text>
    </view>
  </view>

  <!-- 加载遮罩 -->
  <view class="loading-mask" wx:if="{{loading}}">
    <view class="loading-content">
      <text class="loading-text">登录中...</text>
    </view>
  </view>
</view>