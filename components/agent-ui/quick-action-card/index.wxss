.quick-action-card {
  margin-top: 12px;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
  border: 1px solid rgba(67, 106, 244, 0.12);
}

.quick-action-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.quick-action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2329;
}

.quick-action-tag {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(67, 106, 244, 0.12);
  color: #436af4;
  font-size: 22rpx;
}

.quick-action-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #70809e;
}

.quick-action-error {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #d54941;
  line-height: 1.5;
}

.quick-action-button {
  margin-top: 18rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  background: #436af4;
}

.quick-action-button.status-executing {
  background: #8ca5ff;
}

.quick-action-button.status-completed {
  background: #2fb36d;
}

.quick-action-button.status-failed {
  background: #ea6b4a;
}
