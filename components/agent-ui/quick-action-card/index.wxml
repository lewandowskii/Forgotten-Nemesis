<view class="quick-action-card">
  <view class="quick-action-header">
    <view class="quick-action-title">{{action.title}}</view>
    <view class="quick-action-tag">快捷操作</view>
  </view>

  <view class="quick-action-meta" wx:if="{{action.payload}}">
    <text>{{action.payload.memoryType === 'birthday' ? '生日' : (action.payload.memoryType === 'anniversary' ? '纪念日' : (action.payload.memoryType === 'holiday' ? '节日' : '纪念日'))}}</text>
    <text>·</text>
    <text>{{action.payload.dateType === 'lunar' ? '农历' : '公历'}}</text>
    <text>·</text>
    <text>{{action.payload.targetDate}}</text>
  </view>

  <view class="quick-action-error" wx:if="{{action.errorMessage}}">
    {{action.errorMessage}}
  </view>

  <view
    class="quick-action-button status-{{action.status}}"
    bindtap="handleExecute"
  >
    <block wx:if="{{action.status === 'executing'}}">创建中...</block>
    <block wx:elif="{{action.status === 'completed'}}">已创建</block>
    <block wx:elif="{{action.status === 'failed'}}">重试创建</block>
    <block wx:else>创建到纪念日</block>
  </view>
</view>
