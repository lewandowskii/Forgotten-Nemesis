.calendar-container {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.calendar-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.month-nav {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.nav-icon {
  font-size: 36rpx;
  color: #0052D9;
  font-weight: 500;
}

.month-title {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.year-text {
  font-size: 28rpx;
  color: #666;
}

.month-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.week-header {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  margin-bottom: 16rpx;
}

.week-day {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 12rpx 0;
  font-weight: 500;
}

.week-day.weekend {
  color: #FF6B6B;
}

.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.calendar-cell {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  position: relative;
}

.calendar-cell.empty {
  background: transparent;
}

.calendar-cell.today {
  background: #E8F3FF;
}

.calendar-cell.selected {
  background: #0052D9;
}

.day-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.day-number {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.calendar-cell.selected .day-number,
.day-number.selected-text {
  color: #fff;
  font-weight: 600;
}

.day-number.today-text {
  color: #0052D9;
  font-weight: 600;
}

/* 纪念日标记样式 */
.memory-indicator {
  position: absolute;
  bottom: 4rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
}

.memory-indicator.in-month {
  background: #0052D9;
}

.memory-indicator.upcoming {
  background: #F59E0B;
}

/* 旧样式保留兼容 */
.upcoming-indicator {
  position: absolute;
  bottom: 4rpx;
  width: 10rpx;
  height: 10rpx;
  background: #F59E0B;
  border-radius: 50%;
}

.event-dots {
  display: flex;
  gap: 4rpx;
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
}

.event-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
}

.calendar-cell.selected .event-dot {
  background: rgba(255, 255, 255, 0.8) !important;
}

/* 特殊日期样式 */
.calendar-cell.special-day {
  background: linear-gradient(135deg, #fff5f5 0%, #ffe4e4 100%);
}

.calendar-cell.special-day.selected {
  background: linear-gradient(135deg, #FF6B6B 0%, #ff8e8e 100%);
}

.special-indicator {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
}

.special-icon {
  font-size: 16rpx;
}

.special-number {
  color: #FF6B6B !important;
  font-weight: 600 !important;
}

.calendar-cell.special-day.selected .special-number {
  color: #fff !important;
}

/* 农历文本样式 */
.lunar-text {
  font-size: 18rpx;
  color: #999;
  margin-top: 2rpx;
  display: block;
  text-align: center;
}

.calendar-cell.selected .lunar-text,
.calendar-cell.today .lunar-text {
  color: inherit;
  opacity: 0.8;
}
