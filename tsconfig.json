{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "lib": ["ES2018"],
    "declaration": false,
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "~/*": ["/*"]
    },
    "typeRoots": ["./types", "./node_modules/@types"],
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": [
    "**/*.ts",
    "types/**/*.ts",
    "types/*.d.ts"
  ],
  "typeAcquisition": {
    "enable": true,
    "include": [
      "node_modules/@types"
    ]
  },
  "exclude": [
    "node_modules",
    "miniprogram_npm",
    "dist"
  ]
}