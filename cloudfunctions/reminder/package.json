{
  "name": "reminder",
  "version": "1.0.0",
  "description": "纪念日提醒定时任务云函数",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "wx-server-sdk": "~2.6.3",
    "axios": "^1.6.0"
  },
  "cloudfunction-config": {
    "memorySize": 256,
    "timeout": 60,
    "path": "/reminder",
    "runtime": "Nodejs18.15",
    "triggers": [
      {
        "name": "dailyReminder",
        "type": "timer",
        "config": "0 0 8 * * * *"
      }
    ],
    "handler": "index.main"
  }
}
